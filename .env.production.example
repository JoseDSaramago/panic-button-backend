NODE_ENV=production
PORT=3000

# ── MySQL ─────────────────────────────────────────────────────────────────────
DB_HOST=panicbutton-production-mysqldb
DB_PORT=3306
DB_USER=root
DB_PASSWORD=CAMBIA_ESTO_POR_PASSWORD_SEGURO
DB_NAME=panicbutton_db_production

# ── JWT — usa strings largos y aleatorios en producción ───────────────────────
JWT_SECRET=CAMBIA_ESTO_minimo_32_caracteres_aleatorios
JWT_REFRESH_SECRET=CAMBIA_ESTO_minimo_32_caracteres_aleatorios_diferente

# ── Brevo ─────────────────────────────────────────────────────────────────────
BREVO_API_KEY=tu_api_key_de_brevo
BREVO_WHATSAPP_TEMPLATE=nombre_del_template
BREVO_SENDER_NUMBER=521XXXXXXXXXX
BREVO_SMS_SENDER=PanicBtn

# ── Sentry (recomendado en producción para monitorear errores) ────────────────
SENTRY_DSN=

# ── CORS — dominios del frontend en producción ────────────────────────────────
CORS_ORIGINS=https://tudominio.com,https://app.tudominio.com

# ── Retención GPS en días ─────────────────────────────────────────────────────
GPS_RETENTION_DAYS=90
